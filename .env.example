# ── Firebase Web (client) — copy from Firebase Console → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (server only) — from a service account JSON (never commit real keys)
# Use literal \n in the private key string for multiline PEM in .env
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Admin access (middleware + /api/admin/session)
# Comma-separated emails allowed to open /admin after Firebase Auth sign-in
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com
ADMIN_EMAILS=admin@example.com

# Optional: set in production
# NODE_ENV=production
