rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userSnapshot(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return signedIn() && userExists(request.auth.uid)
        ? userSnapshot(request.auth.uid).data.role
        : null;
    }

    function configDoc() {
      return get(/databases/$(database)/documents/hackathon_config/global);
    }

    function configExists() {
      return exists(/databases/$(database)/documents/hackathon_config/global);
    }

    function currentPhase() {
      return configExists() ? configDoc().data.currentPhase : null;
    }

    function psSelectionLocked() {
      return configExists() && configDoc().data.psSelectionLocked == true;
    }

    function submissionLocked() {
      return configExists() && configDoc().data.submissionLocked == true;
    }

    function submissionDeadlinePassed() {
      return configExists()
        && configDoc().data.submissionDeadline != null
        && request.time > configDoc().data.submissionDeadline;
    }

    function eventControlsPath() {
      return /databases/$(database)/documents/event_controls/global;
    }

    function eventControlsExists() {
      return exists(eventControlsPath());
    }

    function eventControlsData() {
      return get(eventControlsPath()).data;
    }

    function registrationWindowOpen(track) {
      let controls = eventControlsExists() ? eventControlsData() : null;
      let registration = controls == null ? null : controls.registration;
      let window = track == "workshop"
        ? (registration == null ? null : registration.workshop)
        : (registration == null ? null : registration.hackathon);

      return controls == null
        || window == null
        || (
          (window.enabled == true || window.enabled == null)
          && (window.openAt == null || request.time >= window.openAt)
          && (window.closeAt == null || request.time < window.closeAt)
        );
    }

    function registrationWindowOpenByType(registrationType) {
      return (registrationType == "workshop" && registrationWindowOpen("workshop"))
        || (registrationType == "hackathon" && registrationWindowOpen("hackathon"));
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true || myRole() == "ADMIN");
    }

    function isTeamLead() {
      return signedIn() && myRole() == "TEAM_LEAD";
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function selfCreateRoleIsAllowed() {
      return !("role" in request.resource.data)
        || request.resource.data.role == "PARTICIPANT";
    }

    function selfUpdateRoleIsAllowed() {
      let changedRole = request.resource.data.diff(resource.data).changedKeys().hasAny(["role"]);

      return !changedRole
        || (!("role" in resource.data) && request.resource.data.role == "PARTICIPANT");
    }

    // Team flow collections imported from companion repo.
    match /hackathon_config/{docId} {
      allow read: if docId == "global" || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create: if isAdmin() || (isSelf(uid) && selfCreateRoleIsAllowed());
      allow update: if isAdmin() || (isSelf(uid) && selfUpdateRoleIsAllowed());
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.leadUid == request.auth.uid
            || ("memberUids" in resource.data && request.auth.uid in resource.data.memberUids)
          )
        );

      allow create: if isTeamLead();

      allow update: if isAdmin()
        || (
          isTeamLead()
          && resource.data.leadUid == request.auth.uid
          && (
            (
              currentPhase() == "PS_SELECTION"
              && !psSelectionLocked()
              && !(resource.data.psSelection.locked == true)
              && request.resource.data.psSelection.locked == true
              && request.resource.data.psSelection.selected == true
            )
            || (
              currentPhase() == "SUBMISSION"
              && !submissionLocked()
              && !submissionDeadlinePassed()
              && !(resource.data.submission.locked == true)
              && request.resource.data.submission.locked == true
              && request.resource.data.submission.submitted == true
            )
          )
        );

      allow delete: if isAdmin();
    }

    match /workshop_registrations/{docId} {
      allow read, write: if isAdmin();
    }

    match /hackathon_registrations/{docId} {
      allow read, write: if isAdmin();
    }

    match /participants/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /transactions/{docId} {
      allow read, write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    // Dedicated team access and future hackathon workflow collections are server-only.
    match /team_access_accounts/{docId} {
      allow read, write: if false;
    }

    match /team_access_index/{docId} {
      allow read, write: if false;
    }

    match /problem_statements/{docId} {
      allow read, write: if false;
    }

    match /team_problem_selection/{docId} {
      allow read, write: if false;
    }

    match /submissions/{docId} {
      allow read, write: if false;
    }

    // Legacy compatibility collection retained as admin-only.
    match /registrations/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
