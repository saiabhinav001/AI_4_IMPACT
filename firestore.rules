rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userSnapshot(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return signedIn() && userExists(request.auth.uid)
        ? userSnapshot(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true || myRole() == "ADMIN");
    }

    function isTeamLead() {
      return signedIn() && myRole() == "TEAM_LEAD";
    }

    function configDoc() {
      return get(/databases/$(database)/documents/hackathon_config/global);
    }

    function configExists() {
      return exists(/databases/$(database)/documents/hackathon_config/global);
    }

    function currentPhase() {
      return configExists() ? configDoc().data.currentPhase : null;
    }

    function psSelectionLocked() {
      return configExists() && configDoc().data.psSelectionLocked == true;
    }

    function submissionLocked() {
      return configExists() && configDoc().data.submissionLocked == true;
    }

    function submissionDeadlinePassed() {
      return configExists()
        && configDoc().data.submissionDeadline != null
        && request.time > configDoc().data.submissionDeadline;
    }

    // Public read of global hackathon config (phase, locks, timeline) for dashboards / future landing widgets.
    match /hackathon_config/{docId} {
      allow read: if docId == "global" || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.leadUid == request.auth.uid
            || ("memberUids" in resource.data && request.auth.uid in resource.data.memberUids)
          )
        );

      allow create: if isTeamLead();

      allow update: if isAdmin()
        || (
          isTeamLead()
          && resource.data.leadUid == request.auth.uid
          && (
            (
              currentPhase() == "PS_SELECTION"
              && !psSelectionLocked()
              && !(resource.data.psSelection.locked == true)
              && request.resource.data.psSelection.locked == true
              && request.resource.data.psSelection.selected == true
            )
            || (
              currentPhase() == "SUBMISSION"
              && !submissionLocked()
              && !submissionDeadlinePassed()
              && !(resource.data.submission.locked == true)
              && request.resource.data.submission.locked == true
              && request.resource.data.submission.submitted == true
            )
          )
        );

      allow delete: if isAdmin();
    }

    // Workshop rows are created by server (Admin SDK) for public form; authenticated users may register via client later.
    match /workshop_registrations/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(["college", "phone", "payment", "status"])
        && request.resource.data.payment is map;
      allow read: if isAdmin()
        || (signedIn()
          && resource.data.uid != ""
          && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Legacy hackathon form (still written by Admin API; optional direct client create if enabled later).
    match /registrations/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
