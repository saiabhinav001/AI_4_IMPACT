{
  "hosting": {
    "site": "ai4impact",
    "public": "out",
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/",
        "destination": "https://ai4impact-backend--ai4impact-cc315.us-central1.hosted.app/",
        "type": 302
      },
      {
        "source": "/:path*",
        "destination": "https://ai4impact-backend--ai4impact-cc315.us-central1.hosted.app/:path*",
        "type": 302
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "apphosting": [
    {
      "backendId": "ai4impact-backend",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        ".firebase",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "out",
        ".next"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
