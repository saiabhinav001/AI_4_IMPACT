{
  "hosting": {
    "site": "ai4impact",
    "public": "out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "apphosting": [
    {
      "backendId": "ai4impact-backend",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        ".firebase",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "out",
        ".next"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
