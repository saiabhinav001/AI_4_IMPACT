{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "deploy:hosting:static": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1",
    "apphosting:backends:list": "npx firebase-tools apphosting:backends:list --project ai4impact-cc315",
    "apphosting:backend:get": "npx firebase-tools apphosting:backends:get ai4impact-backend --project ai4impact-cc315",
    "apphosting:deploy:source": "powershell -ExecutionPolicy Bypass -File ./deploy-apphosting.ps1 -ProjectId ai4impact-cc315 -BackendId ai4impact-backend -SourceDeploy -Force",
    "apphosting:rollout:main": "powershell -ExecutionPolicy Bypass -File ./deploy-apphosting.ps1 -ProjectId ai4impact-cc315 -BackendId ai4impact-backend -GitBranch main -Force",
    "health:runtime": "node scripts/check-runtime-endpoints.mjs",
    "db:clear-test-data": "node scripts/clear-test-data.cjs",
    "audit:storage-refs": "node scripts/audit-storage-references.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2"
  }
}
