rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    // Payment screenshots and final decks are uploaded via Next.js API routes using the Admin SDK.
    // Security Rules do not apply to Admin uploads; these rules block direct browser SDK access to sensitive paths.
    match /payments/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /submissions/{teamId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
